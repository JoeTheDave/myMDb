# Production environment variables
# These are set as Fly.io secrets (fly secrets set KEY=value)
# Never commit real values to this file or fly.toml

# Fly internal Postgres URL — use .flycast internal address with sslmode=disable
DATABASE_URL=

# JWT signing secret — must be at least 32 characters, randomly generated
JWT_SECRET=

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production callback URL registered in Google Cloud Console
# e.g. https://mymdb.fly.dev/api/auth/google/callback
GOOGLE_CALLBACK_URL=

# AWS IAM credentials scoped to mymdb S3 buckets only
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Use mymdb-prod-assets for production, mymdb-dev-assets for staging
AWS_BUCKET_NAME=mymdb-prod-assets
